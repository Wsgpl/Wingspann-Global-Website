# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://wingspannglobal.com

# ── Database (get from Hostinger hPanel → Databases) ─────────────────────────
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=wingspann_db

# ── SMTP (get from Hostinger hPanel → Email → your account → SMTP settings) ──
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@wingspannglobal.com
SMTP_PASS=your_email_password

# ── Email recipients ──────────────────────────────────────────────────────────
EMAIL_INFO=info@wingspannglobal.com
EMAIL_HR=hr@wingspannglobal.com
EMAIL_TECH=d.sengupta@wingspannglobal.com
